# Copy to ".env" in this folder and set values. ".env" is gitignored.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini
# Optional: lower if you get HTTP 402 on low balance (default 3000).
# OPENROUTER_MAX_TOKENS=1024

# USDA FoodData Central — free API key (recommended for generic foods + portion grams).
# https://fdc.nal.usda.gov/api-key-signup
USDA_FDC_API_KEY=
# Optional: skip USDA lookups (e.g. offline dev).
# USDA_FDC_DISABLED=1

# Optional: frontend (`frontend/.env`) — override API origin for Vite dev server
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: skip Open Food Facts HTTP; USDA FDC (if configured) and static fallback still apply before LLM.
# OPENFOODFACTS_DISABLED=1
# Custom User-Agent for OFF (recommended for production traffic).
# OPENFOODFACTS_USER_AGENT=MyApp/1.0 (contact@example.com)
